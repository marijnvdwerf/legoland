#!/usr/bin/env python3
"""CMake -> MSVC6 LINK.EXE shim.

wibo (1.1.0) can't build a PE import section — it lacks kernel32!GetTempFileNameW,
which LINK calls whenever an object references a DLL import. So LINK runs through
CrossOver wine in a bottle (the same wine reccmp uses). Compilation still uses wibo
(see the `cl` wrapper); linking is once per build, so wine's overhead is fine.

Override the wine binary / bottle with LEGOLAND_WINE / CX_BOTTLE.
"""
import os
import pathlib
import subprocess
import sys

ROOT = pathlib.Path(__file__).resolve().parents[2]
LINK = str(ROOT / "toolchain" / "msvc6" / "Bin" / "LINK.EXE")
LIBS = ROOT / "libs"  # committed system import libs (not downloadable)

_default_wine = pathlib.Path.home() / (
    "Applications/CrossOver.app/Contents/SharedSupport/CrossOver/bin/wine"
)
WINE = os.environ.get("LEGOLAND_WINE") or str(_default_wine)
if not os.path.exists(WINE):
    WINE = "/Applications/CrossOver.app/Contents/SharedSupport/CrossOver/bin/wine"

# LINK flags whose value is a path glued after a colon, e.g. /OUT:Z:\a\b.exe
COLON_FLAGS = ("/OUT:", "/PDB:", "/IMPLIB:", "/LIBPATH:", "/MAP:", "/DEF:")


def to_win(p: str) -> str:
    return "Z:" + p.replace("/", "\\")


def is_abs_path(tok: str) -> bool:
    if not tok.startswith("/"):
        return False
    first = tok[1:].split("/", 1)[0]
    return first != "" and os.path.isdir("/" + first)


def conv(tok: str) -> str:
    for f in COLON_FLAGS:
        if tok.upper().startswith(f):
            rest = tok[len(f) :]
            return tok[: len(f)] + (to_win(rest) if is_abs_path(rest) else rest)
    if is_abs_path(tok):
        return to_win(tok)
    return tok


def main() -> int:
    args = [conv(a) for a in sys.argv[1:]]
    # Append the committed system import libs (LINK pulls only referenced symbols).
    import_libs = sorted(p.name for p in LIBS.glob("*.lib"))
    env = dict(os.environ)
    env.setdefault("CX_BOTTLE", "Visual C++ 6.0 SP6")
    env["LIB"] = to_win(str(LIBS))
    return subprocess.call([WINE, LINK, *args, *import_libs], env=env)


if __name__ == "__main__":
    raise SystemExit(main())
